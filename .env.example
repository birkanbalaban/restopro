# RestoPro Environment Configuration Template
# 
# This file serves as a template for environment configuration.
# 
# DEVELOPMENT:
#   - Copy to .env.local and edit for your local environment
#   - .env.local is git-ignored (never committed)
# 
# PRODUCTION:
#   - Create .env on production server with explicit values
#   - .env is git-ignored (never committed)
#   - All values must be explicitly set (no reliance on defaults)
# 
# PRECEDENCE:
#   .env.local overrides .env
#   .env provides defaults
#   .env.example is tracked (reference for all developers)
# 
# ============================================================================
# ENVIRONMENT SELECTION
# ============================================================================

# Application environment (affects logging, caching, error detail)
# Values: development | production | test
# Default: development
NODE_ENV=development

# Debug logging namespace (used by debug module)
# Example: restopro:* for all, restopro:api for just API, empty to disable
# Default: restopro:*
DEBUG=restopro:*

# ============================================================================
# FRONTEND / VITE (Browser-available via import.meta.env)
# ============================================================================

# Port for Vite development server (npm run dev only)
# Note: Production uses built static files, not Vite dev server
# Default: 3010
VITE_PORT=3010

# API URL that frontend uses to connect to backend
# Example: http://localhost:3005 (local dev)
# Example: http://192.168.1.100:3005 (local network)
# Example: https://api.restopro.com (production)
# Default: http://localhost:3005
VITE_API_URL=http://localhost:3005

# Enable Vite debug mode in browser console
# Values: true | false
# Default: false
VITE_ENABLE_DEBUG=false

# ============================================================================
# BACKEND / EXPRESS API SERVER
# ============================================================================

# Port for Express backend API server
# Default: 3005
API_PORT=3005

# Host/IP address for Express to bind to
# 0.0.0.0: Listen on all network interfaces (accessible from other machines)
# 127.0.0.1: Listen only on localhost (local machine only)
# Default: 0.0.0.0
LISTEN_HOST=0.0.0.0

# Host/IP that clients should use to reach this server
# localhost: Use for local development
# Your server's IP (e.g., 192.168.1.100): Use for network access
# DNS name (e.g., restopro.local): Use for DNS-based access
# Default: localhost
SERVER_HOST=localhost

# ============================================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================================

# CORS allowed origins
# Development: * (allows all origins - development only!)
# Production: https://yourdomain.com (specific domain)
# Multiple: https://domain1.com,https://domain2.com
# Default: *
CORS_ORIGIN=*

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite database file location
# Relative path: ./data/restopro.db (relative to application root)
# Absolute path: /var/lib/restopro/restopro.db (production)
# Default: ./data/restopro.db
DATABASE_PATH=./data/restopro.db

# Backup directory for database backups (used in Phase 3+)
# Default: ./data/backups
DATABASE_BACKUP_PATH=./data/backups

# Enable WAL (Write-Ahead Logging) mode for better concurrency
# Values: true | false
# Default: false (will be enabled in production in Phase 3)
DATABASE_WAL_MODE=false

# ============================================================================
# OPTIONAL FEATURES & FLAGS
# ============================================================================

# Disable HMR (Hot Module Replacement) for Vite dev server
# Set to 'true' to disable (useful in restricted environments like AI Studio)
# Values: true | false
# Default: false
DISABLE_HMR=false

# ============================================================================
# NOTES FOR DEPLOYMENT TEAM
# ============================================================================
# 
# 1. LOCAL DEVELOPMENT:
#    - Copy this file to .env.local
#    - Edit values as needed for your local setup
#    - .env.local is git-ignored (your local overrides)
#    - Restart both frontend (npm run dev) and backend (npm run server)
# 
# 2. PRODUCTION SETUP:
#    - Create .env on production server with explicit values
#    - At minimum, set:
#      * NODE_ENV=production
#      * SERVER_HOST=<your-server-ip>
#      * VITE_API_URL=http://<your-server-ip>:3005
#      * DATABASE_PATH=/var/lib/restopro/restopro.db (with proper permissions)
# 
# 3. VERIFICATION:
#    - npm run server should start and print the actual port/host
#    - npm run dev should start Vite and print the dev server URL
#    - Open http://localhost:3010 and check browser console for API errors
#    - Check that .env and .env.local do NOT appear in git status
# 
# 4. SECURITY:
#    - NEVER commit .env files to git (they're ignored)
#    - .env.example is tracked (safe template)
#    - Keep .env and .env.local secure on servers and dev machines
#
